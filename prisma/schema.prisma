generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ThreatLog {
  id        String   @id @default(uuid())
  indicator String
  type      String
  severity  Int
  createdAt DateTime @default(now())

  @@map("threat_logs")
}
