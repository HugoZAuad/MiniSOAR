generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ThreatLog {
  id              String   @id @default(uuid())
  indicator       String
  type            String
  severity        Int
  containment     Boolean  @default(false)
  country         String?
  reputationScore Int?
  recurrencyCount Int      @default(0)
  hybridScore     Float    @default(0.0)
  createdAt       DateTime @default(now())

  @@map("threat_logs")
}
